generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum DeviceType {
  desktop
  mobile
}

model Project {
  id          String       @id @default(cuid())
  name        String       @unique
  domain      String?
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  keywords      Keyword[]
  competitors   Competitor[]
  rankSnapshots   RankSnapshot[]
  pageKeywords  PageKeyword[]

  @@index([domain])
}

model Keyword {
  id        String     @id @default(cuid())
  projectId String
  keyword   String
  targetUrl String
  geo       String     @default("us")
  device    DeviceType @default(desktop)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  project       Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rankSnapshots RankSnapshot[]

  @@unique([projectId, keyword, targetUrl, geo, device])
  @@index([projectId, isActive])
}

model Competitor {
  id        String   @id @default(cuid())
  projectId String
  domain    String
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project         Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshotEntries CompetitorRankSnapshot[]

  @@unique([projectId, domain])
  @@index([projectId])
}

model RankSnapshot {
  id             String     @id @default(cuid())
  projectId      String
  keywordId      String
  checkedAt      DateTime   @default(now())
  targetPosition Int?
  totalResults   Int?
  serpFeatures   Json?
  results        Json?
  provider       String     @default("mock")

  project     Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  keyword     Keyword                  @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  competitors CompetitorRankSnapshot[]

  @@index([projectId, checkedAt])
  @@index([keywordId, checkedAt])
}

model CompetitorRankSnapshot {
  id           String   @id @default(cuid())
  snapshotId   String
  competitorId String
  position     Int?
  found        Boolean  @default(false)
  createdAt    DateTime @default(now())

  snapshot   RankSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  competitor Competitor   @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, competitorId])
  @@index([competitorId, createdAt])
}

model PageKeyword {
  id           String     @id @default(cuid())
  projectId    String
  pageUrl      String
  keyword      String
  geo          String     @default("us")
  device       DeviceType @default(desktop)
  isActive     Boolean    @default(true)
  notes        String?
  checkDepth   Int        @default(100)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  project   Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  positions PageKeywordPosition[]

  @@unique([projectId, pageUrl, keyword, geo, device])
  @@index([projectId, isActive])
  @@index([pageUrl])
}

model PageKeywordPosition {
  id            String   @id @default(cuid())
  pageKeywordId String
  position      Int?
  totalResults  Int?
  serpFeatures  Json?
  topResults    Json?
  checkedAt     DateTime @default(now())

  pageKeyword PageKeyword @relation(fields: [pageKeywordId], references: [id], onDelete: Cascade)

  @@index([pageKeywordId, checkedAt])
  @@index([checkedAt])
}
